{
  "_comment": "Entry family weights for deterministic scoring (Redis-only live path). No LLM.",
  "_version": "2.0",
  "_updated": "2026-05-20 — Added EMA5/EMA200 scoring. ST boost, TF weights, ADX kept for DuckDB path.",

  "trend": {
    "description": "EMA alignment within 60min TF. Traffic Light handles multi-TF diversification.",
    "ema_weights": {
      "5": 0.35,
      "20": 0.30,
      "50": 0.25,
      "100": 0.20,
      "200": 0.15
    },
    "tf_weights": {
      "_note": "Used by DuckDB score_trend() only — not the Redis live path",
      "5m": 0.10,
      "15m": 0.15,
      "30m": 0.15,
      "60m": 0.20,
      "240m": 0.20,
      "1440m": 0.20
    },
    "adx": {
      "_note": "Used by DuckDB score_trend() only",
      "noise_threshold": 10,
      "weak_threshold": 20,
      "trending_threshold": 25,
      "strong_threshold": 35,
      "noise_penalty": 0.0,
      "weak_multiplier": 0.5,
      "trending_multiplier": 1.0,
      "strong_multiplier": 1.3
    },
    "st_boost": 2.0,
    "signal_thresholds": {
      "bullish": 3.0,
      "bearish": -3.0
    },
    "confidence": {
      "_note": "Used by DuckDB score_trend() only. Redis path uses inline math.",
      "full_alignment": 90,
      "high_alignment": 70,
      "mixed": 40,
      "no_data": 15,
      "penalty_per_missing_tf": 12
    }
  },

  "traffic_light": {
    "description": "Pattern scores — 6 TF candle colors + GAP (7th light). Higher TFs dominate.",
    "gap_weight": 0.2,
    "patterns": {
      "STRONG_BEAR_CONTINUATION":   { "score": -9, "confidence": 0 },
      "BEARISH_CONTINUATION":       { "score": -8, "confidence": 0 },
      "DEAD_CAT_BOUNCE":            { "score": -6, "confidence": 0 },
      "BEARISH_STRUCTURE":          { "score": -5, "confidence": 0 },
      "CHOPPY_INDECISION":          { "score": 0, "confidence": 0 },
      "mixed":                      { "score": 0, "confidence": 0 },
      "BULLISH_DEEP_PULLBACK_BOUNCING": { "score": 4, "confidence": 0 },
      "BULLISH_STRUCTURE":          { "score": 5, "confidence": 0 },
      "BULLISH_MILD_PULLBACK":      { "score": 6, "confidence": 0 },
      "MOMENTUM_PEAK":              { "score": 0, "confidence": 0, "note": "All green = exhaustion. Score 0: direction from gap. Base conf 0: reliability to be learned from research." },
      "BULLISH_PULLBACK_RESUMING":  { "score": 7, "confidence": 0 },
      "BULLISH_CONTINUATION":       { "score": 8, "confidence": 0 }
    },
    "signal_thresholds": {
      "bullish": 3.0,
      "bearish": -3.0
    }
  },

  "combine": {
    "description": "Merge Trend + Traffic Light into GO/NO-GO + suggested trade.",
    "rules": {
      "both_bullish":        { "go": true,  "confidence_mult": 1.0,  "strategy": "PUT_SPREAD" },
      "both_bearish":        { "go": true,  "confidence_mult": 1.0,  "strategy": "CALL_SPREAD" },
      "bullish_plus_neutral": { "go": true,  "confidence_mult": 0.75, "strategy": "PUT_SPREAD" },
      "bearish_plus_neutral": { "go": true,  "confidence_mult": 0.75, "strategy": "CALL_SPREAD" },
      "conflict":            { "go": false, "confidence_mult": 0.3,  "strategy": "NONE" },
      "both_neutral":        { "go": true,  "confidence_mult": 0.5,  "strategy": "IRON_BUTTERFLY" }
    },
    "go_threshold": {
      "min_confidence": 0,
      "note": "Paper mode: take ALL non-conflict trades. Only skip on BULLISH vs BEARISH signal conflict."
    }
  }
}
