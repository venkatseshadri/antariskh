{
  "_comment": "Entry family weights for deterministic scoring. No LLM needed for these calculations.",
  "_version": "1.0",
  "_phase": "Phase 1 — equal weights. RL adjusts post-session.",

  "trend": {
    "description": "Per-TF weights for SMA/EMA directional scoring",
    "tf_weights": {
      "5m": 0.10,
      "15m": 0.15,
      "30m": 0.15,
      "60m": 0.20,
      "240m": 0.20,
      "1440m": 0.20
    },
    "adx": {
      "noise_threshold": 10,
      "weak_threshold": 20,
      "trending_threshold": 25,
      "strong_threshold": 35,
      "noise_penalty": 0.0,
      "weak_multiplier": 0.5,
      "trending_multiplier": 1.0,
      "strong_multiplier": 1.3
    },
    "st_boost": 2.0,
    "signal_thresholds": {
      "bullish": 3.0,
      "bearish": -3.0
    },
    "confidence": {
      "full_alignment": 90,
      "high_alignment": 70,
      "mixed": 40,
      "no_data": 15,
      "penalty_per_missing_tf": 12
    }
  },

  "traffic_light": {
    "description": "Pattern scores — higher TF patterns dominate",
    "patterns": {
      "STRONG_BEAR_CONTINUATION":   { "score": -9, "confidence": 90 },
      "STRONG_BULL_CONTINUATION":   { "score": 9, "confidence": 90, "pattern": "all_green" },
      "BULLISH_CONTINUATION":       { "score": 8, "confidence": 80 },
      "BEARISH_CONTINUATION":       { "score": -8, "confidence": 80 },
      "BULLISH_PULLBACK_RESUMING":  { "score": 7, "confidence": 70 },
      "BULLISH_MILD_PULLBACK":      { "score": 6, "confidence": 65 },
      "BULLISH_STRUCTURE":          { "score": 5, "confidence": 65 },
      "BULLISH_DEEP_PULLBACK_BOUNCING": { "score": 4, "confidence": 55 },
      "BEARISH_STRUCTURE":          { "score": -5, "confidence": 65 },
      "DEAD_CAT_BOUNCE":            { "score": -6, "confidence": 60 },
      "CHOPPY_INDECISION":          { "score": 0, "confidence": 20 },
      "MOMENTUM_PEAK":              { "score": 2, "confidence": 70, "note": "bullish but exhaustion risk" },
      "mixed":                      { "score": 0, "confidence": 30 }
    },
    "signal_thresholds": {
      "bullish": 3.0,
      "bearish": -3.0
    }
  },

  "combine": {
    "description": "How to merge Trend + Traffic Light into a single decision",
    "rules": {
      "both_bullish":        { "go": true,  "confidence_mult": 1.0,  "strategy": "PUT_CREDIT_SPREAD" },
      "both_bearish":        { "go": true,  "confidence_mult": 1.0,  "strategy": "CALL_CREDIT_SPREAD" },
      "bullish_plus_neutral": { "go": true,  "confidence_mult": 0.75, "strategy": "PUT_CREDIT_SPREAD" },
      "bearish_plus_neutral": { "go": true,  "confidence_mult": 0.75, "strategy": "CALL_CREDIT_SPREAD" },
      "conflict":            { "go": false, "confidence_mult": 0.3,  "strategy": "NONE" },
      "both_neutral":        { "go": true,  "confidence_mult": 0.5,  "strategy": "IRON_BUTTERFLY" }
    },
    "go_threshold": {
      "min_confidence": 35,
      "note": "If combined confidence < 35, force NO-GO regardless of signal"
    }
  }
}
